{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@faker-js/faker": "^9.8.0",
    "@httpbin-monitor/shared": "workspace:*",
    "@prisma/client": "^6.8.2",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "lru-cache": "^11.1.0",
    "node-cron": "^4.1.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.8.2",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "@vitest/coverage-v8": "^3.2.3",
    "vitest": "^3.2.3"
  }
}
